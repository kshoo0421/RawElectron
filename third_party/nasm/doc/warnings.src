\c      pp-macro-params-legacy
\c      pp-macro-params-multi
\c      pp-macro-params-single
\c      pp-macro-redef-multi
\c      pp-open-braces
\c      pp-open-brackets
\c      pp-open-string
\c      pp-rep-negative
\c      pp-sel-range
\c      pp-trailing

\b \I{w-pp-else} \c{pp-else}: group alias for:

\c      pp-else-elif
\c      pp-else-else

\b \I{w-pp-macro} \c{pp-macro}: group alias for:

